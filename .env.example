# ─── GadoMarket Pro — Variáveis de Ambiente ───────────────────────
# Copie este arquivo para .env e preencha os valores

# Credenciais de acesso ao sistema
ADMIN_USER=admin
ADMIN_PASS=gado@2024

# Chave secreta para JWT (use uma string longa e aleatória em produção!)
JWT_SECRET=mude-esta-chave-para-algo-secreto-2024

# Porta do servidor (Railway define automaticamente)
PORT=3001

# Caminho do banco de dados SQLite
# No Railway, configure um Volume e aponte para ex: /app/data/gadomarket.db
DB_PATH=./gadomarket.db
